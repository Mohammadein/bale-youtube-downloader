from telegram.ext import Updater, MessageHandler, Filters
from youtube_downloader import download_youtube_video
import subprocess, os

TOKEN = "YOUR_BOT_TOKEN"

def handle_message(update, context):
    url = update.message.text
    update.message.reply_text("Downloading video...")
    try:
        video_path = download_youtube_video(url)
        update.message.reply_text("Compressing file...")
        zip_path = video_path + ".zip"
        subprocess.run(["zip", "-j", zip_path, video_path])
        update.message.reply_text("Splitting file...")
        subprocess.run(["split", "-b", "19M", zip_path, zip_path + ".part"])
        parts = sorted([f for f in os.listdir() if f.startswith(os.path.basename(zip_path) + ".part")])
        for part in parts:
            with open(part, "rb") as f:
                update.message.reply_document(f)
        update.message.reply_text("Upload completed ✅")
        os.remove(video_path)
        os.remove(zip_path)
        for part in parts:
            os.remove(part)
    except Exception as e:
        update.message.reply_text(f"Error: {e}")

def main():
    updater = Updater(TOKEN, base_url="https://tapi.bale.ai/bot/", base_file_url="https://tapi.bale.ai/file/bot/")
    dispatcher = updater.dispatcher

    dispatcher.add_handler(MessageHandler(Filters.text, handle_message))
    updater.start_polling()
    updater.idle()

if __name__ == "__main__":
    main()
