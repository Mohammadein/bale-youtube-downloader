import os
import subprocess

def handle_message(chat_id, text):

    send_message(chat_id, "Downloading video...")

    try:
        video_path = download_youtube_video(text)

        video_dir = os.path.dirname(video_path)
        video_name = os.path.basename(video_path)

        send_message(chat_id, "Compressing file...")

        zip_path = os.path.join(video_dir, video_name + ".zip")

        subprocess.run([
            "zip", "-j", zip_path, video_path
        ])

        send_message(chat_id, "Splitting file...")

        subprocess.run([
            "split",
            "-b", "19M",
            zip_path,
            os.path.join(video_dir, "part_")
        ])

        parts = sorted([
            os.path.join(video_dir, f)
            for f in os.listdir(video_dir)
            if f.startswith("part_")
        ])

        for part in parts:
            send_document(chat_id, part)

        send_message(chat_id, "Upload completed ✅")

    except Exception as e:
        send_message(chat_id, f"Error: {e}")
