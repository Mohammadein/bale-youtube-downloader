import os
import subprocess
from telegram import Update
from telegram.ext import ApplicationBuilder, MessageHandler, ContextTypes, filters

from youtube_downloader import download_youtube_video

BOT_TOKEN = "YOUR_BOT_TOKEN"


async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    url = update.message.text

    await update.message.reply_text("Downloading video...")

    try:
        # Download video
        video_path = download_youtube_video(url)

        await update.message.reply_text("Compressing file...")

        zip_path = video_path + ".zip"

        subprocess.run([
            "zip",
            "-j",
            zip_path,
            video_path
        ])

        await update.message.reply_text("Splitting file...")

        subprocess.run([
            "split",
            "-b",
            "19M",
            zip_path,
            zip_path + ".part"
        ])

        # Collect split parts
        parts = sorted([
            f for f in os.listdir()
            if f.startswith(os.path.basename(zip_path) + ".part")
        ])

        # Send each part
        for part in parts:
            with open(part, "rb") as f:
                await update.message.reply_document(f)

        await update.message.reply_text("Upload completed ✅")

        # Cleanup files
        os.remove(video_path)
        os.remove(zip_path)
        for part in parts:
            os.remove(part)

    except Exception as e:
        await update.message.reply_text(f"Error: {e}")


def main():
    app = (
        ApplicationBuilder()
        .token(BOT_TOKEN)
        .base_url("https://tapi.bale.ai/bot/")
        .base_file_url("https://tapi.bale.ai/file/bot/")
        .build()
    )

    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

    app.run_polling()


if __name__ == "__main__":
    main()
